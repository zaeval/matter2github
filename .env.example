PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
QUEUE_ENABLED=true
QUEUE_FILE=data/queue.json
USERS_FILE=data/users.json
SESSIONS_FILE=data/sessions.json
SETTINGS_FILE=data/settings.json
SESSION_COOKIE_NAME=mmgh_session
SESSION_TTL_SECONDS=604800
GITHUB_MODE=proxy
GITHUB_API_BASE_URL=https://github-proxy.example.com/api/v3
GH_PROXY_TOKEN=replace_with_proxy_token
GITHUB_TOKEN=replace_with_github_token
GITHUB_OWNER=your-github-owner
GITHUB_REPO=your-github-repo
# Set this when the proxy/GitHub TLS chain is signed by a private or
# TLS-intercepting CA (symptom: "fetch failed (SELF_SIGNED_CERT_IN_CHAIN)").
# Put the CA file in ./certs and point to its in-container path. See deploy.md.
NODE_EXTRA_CA_CERTS=
MATTERMOST_TOKEN=mattermost_outgoing_webhook_token
MATTERMOST_ACCESS_TOKEN=mattermost_personal_or_bot_access_token
MATTERMOST_ALLOWED_CHANNELS=
MATTERMOST_BASE_URL=https://mattermost.example.com
# Incoming webhook URL used to post approve/deny/fail results back to Mattermost.
# Leave empty to disable result notifications.
MATTERMOST_WEBHOOK_URL=
TRIGGER_WORDS=!issue,#issue
DEFAULT_LABELS=mattermost,bug
DEFAULT_ASSIGNEES=
ISSUE_TITLE_PREFIX=
ATTACHMENT_STORAGE=github
ATTACHMENT_REPO_PATH=.mattermost-issue-attachments
ATTACHMENT_MAX_BYTES=10485760
ATTACHMENT_MAX_COUNT=10
GITHUB_ATTACHMENT_BRANCH=
AUDIT_LOG_FILE=logs/audit.log
